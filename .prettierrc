{
	"plugins": ["prettier-plugin-svelte"],
	"printWidth": 120,
	"useTabs": true,
	"tabWidth": 4,
	"singleQuote": true,
	"semi": false,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"overrides": [
		{
			"files": "**/*.svelte",
			"options": {
				"parser": "svelte"
			}
		},
		{
			"files": "**/*.json",
			"options": {
				"parser": "json"
			}
		},
		{
			"files": ".prettierrc",
			"options": {
				"parser": "json"
			}
		}
	]
}
